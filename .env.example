# TrendScout AI 2.0 - Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git!

# Scraping
SCRAPER_RATE_LIMIT_SECONDS=2
SCRAPER_MAX_RETRIES=3
SCRAPER_USER_AGENT="TrendScoutBot/1.0 (Academic Research; ASU CSE573)"

# Data Paths
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
CORPUS_FILE=data/processed/corpus.jsonl

# Phase 2+: Neo4j (fill in when ready)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password_here

# Phase 3+: LLM API Keys (fill in when ready)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# HUGGINGFACE_TOKEN=hf_...
