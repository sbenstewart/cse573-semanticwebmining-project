CREATE RANGE INDEX FOR (n:Document) ON (n.published_date);
CREATE RANGE INDEX FOR (n:FundingRound) ON (n.announced_date);
CREATE RANGE INDEX FOR (n:Startup) ON (n.name);
CREATE CONSTRAINT document_id FOR (node:Document) REQUIRE (node.doc_id) IS UNIQUE;
CREATE CONSTRAINT event_name FOR (node:Event) REQUIRE (node.normalized_name) IS UNIQUE;
CREATE CONSTRAINT funding_round_id FOR (node:FundingRound) REQUIRE (node.round_id) IS UNIQUE;
CREATE CONSTRAINT investor_name FOR (node:Investor) REQUIRE (node.normalized_name) IS UNIQUE;
CREATE CONSTRAINT product_name FOR (node:Product) REQUIRE (node.normalized_name) IS UNIQUE;
CREATE CONSTRAINT skill_name FOR (node:Skill) REQUIRE (node.normalized_name) IS UNIQUE;
CREATE CONSTRAINT startup_name FOR (node:Startup) REQUIRE (node.normalized_name) IS UNIQUE;
CREATE CONSTRAINT technology_name FOR (node:Technology) REQUIRE (node.normalized_name) IS UNIQUE;
